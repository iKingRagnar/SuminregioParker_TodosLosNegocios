    "helmet": "^8.1.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "duckdb": "^1.0.0",
    "node-cron": "^4.2.1",
    "node-firebird": "^1.1.5",
    "nodemailer": "^8.0.3",
    "playwright": "^1.58.2",
    "twilio": "^5.13.0",
    "web-push": "^3.6.7"
