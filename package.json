{
  "name": "microsip-api",
  "version": "2.0.0",
  "description": "Suminregio Parker dashboard — consume el API externo https://api.suminregio.com/api/external (ya no conecta Firebird directo)",
  "main": "server_api.js",
  "scripts": {
    "start": "node server_api.js",
    "server": "node server_api.js",
    "start:legacy": "node archive/server_corregido.legacy.js",
