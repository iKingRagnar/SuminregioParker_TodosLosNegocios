# Copiar a .env (no subir .env a Git). Usa usuario de SOLO LECTURA en producción.
PORT=7000
CORS_ORIGIN=*

# Firebird — mismo host para todas las .fdb en el servidor (ruta Windows en el servidor remoto)
FB_HOST=127.0.0.1
FB_PORT=3050
FB_USER=SYSDBA
FB_PASSWORD=cambiar_en_produccion
FB_DATABASE=C:/Microsip datos/SUMINREGIO-PARKER.FDB

# Timeout por defecto de consultas Firebird (ms). Subir si KPIs salen en 0 por timeout.
FB_QUERY_DEFAULT_MS=60000

# Varias empresas (.fdb distintas, mismo host/puerto/credenciales). JSON en una sola línea o multilínea escapada.
# Cada "database" es la ruta en el SERVIDOR donde corre Firebird (como en ODBC).
# FB_DATABASES_JSON=[{"id":"parker","label":"Parker","database":"C:/Microsip datos/SUMINREGIO-PARKER.FDB"},{"id":"agua","label":"Agua","database":"C:/Microsip datos/SUMINREGIO AGUA.FDB"}]

EMPRESA_NOMBRE=Suminregio

# Solo dashboards: desactiva POST /api/email/enviar
# READ_ONLY_MODE=1

# Asistente IA (widget en todas las páginas con nav.js) — API compatible con OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-4o-mini
