# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copia a .env y ajusta. NO commitees tu .env real.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=7000
EMPRESA_NOMBRE=SUMINREGIO PARKER
LOG_LEVEL=info
CORS_ORIGIN=*

# ── DuckDB (modo único de datos recomendado) ─────────────────────────────────
DUCK_ONLY_MODE=1
DUCK_SNAPSHOT_DIR=/var/data/duck_snaps
SNAPSHOT_TOKEN=cambia-este-token-en-produccion
SNAPSHOT_HISTORY_DAYS=7

# ── Firebird (solo si DUCK_ONLY_MODE=0) ──────────────────────────────────────
FB_HOST=127.0.0.1
FB_PORT=3050
FB_USER=SYSDBA
FB_PASSWORD=cambia-este-password
FB_DATABASE=C:/Microsip datos/SUMINREGIO-PARKER.FDB

# ── Performance ──────────────────────────────────────────────────────────────
RENDER_EXTERNAL_URL=https://suminregioparker-todoslosnegocios.onrender.com
KEEPALIVE_MS=600000

# ── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
AI_RATE_MAX=10
AI_RATE_WINDOW_MS=60000

# ── Auth (pluggable) ─────────────────────────────────────────────────────────
# Options: dummy | basic | session | clerk
# En producción (NODE_ENV=production, Render, o RENDER_EXTERNAL_URL): dummy está BLOQUEADO
# salvo ALLOW_INSECURE_DUMMY_AUTH=1 — usa session + SESSION_SECRET + AUTH_USERS.
# Producción interna: AUTH_PROVIDER=session + SESSION_SECRET + AUTH_USERS
AUTH_PROVIDER=dummy
# ALLOW_INSECURE_DUMMY_AUTH=1
# session: cookie httpOnly; CORS_ORIGIN debe ser el origen real (no *) si hay frontend cruzado
SESSION_SECRET=cambia-esto-por-un-secreto-largo-aleatorio-en-produccion
# Formato AUTH_USERS: email:password_contraseña_en_claro:rol  separado por ;
# Roles: admin, gerente, vendedor (varios: admin,gerente). Sin ":" ni ";" en la contraseña.
# Ejemplo (NO uses estas claves en prod):
# AUTH_USERS=roberto.g@suminregio.com:TuPassFuerte1:admin;ximena.r@suminregio.com:TuPassFuerte2:gerente;ana.v@suminregio.com:TuPassFuerte3:vendedor
# Un usuario puede tener varios roles separados por coma: admin,gerente
AUTH_USERS=
# Rate limit login (sesión): intentos por IP antes de 429
AUTH_LOGIN_MAX_ATTEMPTS=12
AUTH_LOGIN_WINDOW_MS=900000
# Para basic:
#   AUTH_USERS=guillermo:pass123:admin;juan:otra:vendedor
# Para clerk:
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── 2FA ──────────────────────────────────────────────────────────────────────
TOTP_SECRET=
REQUIRE_2FA_ADMIN=0

# ── Email reports ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Suminregio <no-reply@suminregio.mx>"
REPORT_TO=
REPORT_HOUR=7
REPORT_DBS=default

# ── Notificaciones ───────────────────────────────────────────────────────────
# Twilio WhatsApp / SMS
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# Slack
SLACK_WEBHOOK_URL=

# Web Push — generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_CONTACT=mailto:admin@suminregio.mx

# Alertas automáticas
ALERT_WEBHOOK_URL=
ALERT_CXC_VENCIDO_PCT=30
ALERT_CHECK_MS=3600000

# ── Storage escalable (Parquet + S3/R2) ──────────────────────────────────────
# Options: local | s3
STORAGE_MODE=local
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=suminregio-snapshots
S3_REGION=auto
S3_KEY=
S3_SECRET=
S3_PREFIX=snapshots/

# ── Observability ────────────────────────────────────────────────────────────
FRESHNESS_WARN_H=30
FRESHNESS_ALERT_H=48

# ── Integraciones ────────────────────────────────────────────────────────────
POWERBI_REFRESH_WEBHOOK=
ZAPIER_WEBHOOK_URL=

# ── Feature flags (migración gradual) ────────────────────────────────────────
USE_NEW_VENTAS=0
USE_NEW_CXC=0
