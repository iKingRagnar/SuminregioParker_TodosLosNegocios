# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Suminregio Parker Dashboard v2.0 (external API mode)
# Copia a .env y ajusta. NUNCA commitees tu .env real.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=7000
NODE_ENV=development
DEFAULT_UNIDAD=parker

# ── API externa de Suminregio (REQUERIDO) ────────────────────────────────────
# La key la emite Omar / el equipo API. Formato: sk_ext_...
# Permisos: 6 unidades + "grupo" consolidado, 70 queries read-only.
SUMINREGIO_API_KEY=sk_ext_PON_AQUI_TU_KEY
SUMINREGIO_API_URL=https://api.suminregio.com/api/external
SUMINREGIO_API_TIMEOUT_MS=20000
SUMINREGIO_API_RETRIES=2

# ── Seguridad ────────────────────────────────────────────────────────────────
# CORS: en prod pon el dominio real, separado por coma si son varios.
CORS_ORIGIN=*

# Basic auth HTTP para toda la UI (recomendado en prod).
# Formato: "usuario:pass;usuario2:pass2". Vacío = sin auth.
AUTH_USERS=

# Rate limit: máximo de requests/minuto por IP sobre /api/*.
RATE_LIMIT_MAX=300

# ── Config local (metas dashboard) ───────────────────────────────────────────
# metas.json en la raíz del repo con:
#   { "META_MES": 3000000, "META_IDEAL": 3300000, "META_ANIO": 36000000 }
# Si falta, el server usa defaults.

# ══════════════════════════════════════════════════════════════════════════════
# LEGACY (ya no se usan — server_api.js no habla Firebird ni cache local).
# Si necesitas arrancar el servidor antiguo: `npm run start:legacy`.
# ══════════════════════════════════════════════════════════════════════════════
# FB_HOST=127.0.0.1
# FB_PORT=3050
# FB_USER=SYSDBA
# FB_PASSWORD=
# FB_DATABASE=
# DUCK_ONLY_MODE=1
# CACHE_MODE=0
